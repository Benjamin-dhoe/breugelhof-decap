<div class="features">
  <div class="container">
    <div class="h2-container">
      <h2 class="h2">{{homepagefeatures.maintitel_en}}</h2>
    </div>
    <div class="collection-list">
      <div class="featuresitem">
        <div class="featureitemholder">
          <h3 class="h3">{{homepagefeatures.mainfeature1titel_en}}</h3>
          <p class="paragraph cc-gray">{{homepagefeatures.mainfeature1tekst_en}}</p>
        </div>
      </div>
      <div class="featuresitem">
        <div class="featureitemholder">
          <h3 class="h3">{{homepagefeatures.mainfeature2titel_en}}</h3>
          <p class="paragraph cc-gray">{{homepagefeatures.mainfeature2tekst_en}}</p>
        </div>
      </div>
    <div class="featuresitem">
        <div class="featureitemholder">
          <h3 class="h3">{{homepagefeatures.mainfeature3titel_en}}</h3>
          <p class="paragraph cc-gray">{{homepagefeatures.mainfeature3tekst_en}}</p>
        </div>
      </div>
    </div>
    <div>
      <div class="separateinsection"></div>
      <h2 class="h2">Amenities</h2>
      <div class="titleline"></div>
      {% set voorzieningenList = homepagefeatures.voorzieningen_en %}
      {% for voorziening in voorzieningenList %}
        <div class="listitem"><img src="/static/img/icons8-checkmark-48.png" loading="lazy" alt="" class="checkicon">
          <div>{{voorziening}}</div>
        </div>
      {% endfor %}
    </div>
    <div>
      <div class="separateinsection"></div>
      <h2 class="h2">Included in the monthly costs</h2>
      <div class="titleline"></div>
      {% set inbegrepenList = homepagefeatures.inbegrepen_en %}
      {% for inbegrepen in inbegrepenList %}
        <div class="listitem"><img src="/static/img/icons8-checkmark-48.png" loading="lazy" alt="" class="checkicon">
          <div>{{inbegrepen}}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
